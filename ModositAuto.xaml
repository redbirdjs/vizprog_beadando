<Window x:Class="vizprog_beadando.ModositAuto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:vizprog_beadando"
        mc:Ignorable="d"
        Title="ModositAuto" Height="200" Width="400">
    <DockPanel Margin="4" VerticalAlignment="Top">
        <DockPanel DockPanel.Dock="Top">
            <Label Content="Márka" Width="60" VerticalAlignment="Center" />
            <TextBox x:Name="marka" VerticalAlignment="Center" Padding="2" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Top">
            <Label Content="Típus" Width="60" VerticalAlignment="Center" />
            <TextBox x:Name="tipus" VerticalAlignment="Center" Padding="2" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Top">
            <Label Content="Bérlés díj" Width="60" VerticalAlignment="Center" />
            <TextBox x:Name="berles_dij" VerticalAlignment="Center" Padding="2" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Bottom" Margin="0 4" HorizontalAlignment="Center">
            <Button x:Name="submitBtn" Content="Módosít" Click="modositClick" Width="100" Margin="4 0" />
            <Button Content="Mégse" Click="megseClick" Width="100" Margin="4 0" />
        </DockPanel>
    </DockPanel>
</Window>
